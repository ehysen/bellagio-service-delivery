# AGP MCP Demo — environment configuration. Copy to .env (or just export these).
# Nothing here is required to run the demo — the extractor falls back to a
# deterministic stub and auth is open when no token is set.

# Port the HTTP server listens on (MCP /mcp + REST /api + /upload + static).
PORT=3000

# Bearer token guarding /mcp, /api, and /upload. If UNSET, the server runs in
# open "demo mode" and logs a loud warning. Set this before exposing publicly.
# AGP_BEARER_TOKEN=changeme-demo-token

# Document-photo extraction backend: "auto" (vision if a key is set, else stub),
# "vision" (force the Claude API), or "stub" (force the deterministic mock).
AGP_EXTRACTOR=auto

# Vision model + provider. Default is Anthropic-direct with claude-opus-4-8.
AGP_VISION_MODEL=claude-opus-4-8
# ANTHROPIC_API_KEY=sk-ant-...
# To route the same @anthropic-ai/sdk through OpenRouter instead, set both:
# AGP_VISION_BASEURL=https://openrouter.ai/api/v1
# OPENROUTER_API_KEY=sk-or-...
